{{- if eq .role "work" -}}
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.openclaw.mcp-calendar</string>

	<key>ProgramArguments</key>
	<array>
		<string>{{ .chezmoi.homeDir }}/Sync/iFIT/tools/assistant/mcp-calendar/bin/CalendarBridge.app/Contents/MacOS/CalendarBridge</string>
	</array>

	<key>WorkingDirectory</key>
	<string>{{ .chezmoi.homeDir }}/Sync/iFIT/tools/assistant/mcp-calendar</string>

	<key>RunAtLoad</key>
	<true/>

	<key>KeepAlive</key>
	<dict>
		<key>SuccessfulExit</key>
		<false/>
	</dict>

	<key>ThrottleInterval</key>
	<integer>5</integer>

	<key>ProcessType</key>
	<string>Interactive</string>

	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>{{ .chezmoi.homeDir }}</string>
	</dict>

	<key>StandardOutPath</key>
	<string>{{ .chezmoi.homeDir }}/Library/Logs/mcp-calendar.log</string>
	<key>StandardErrorPath</key>
	<string>{{ .chezmoi.homeDir }}/Library/Logs/mcp-calendar.err</string>
</dict>
</plist>
{{ end -}}
