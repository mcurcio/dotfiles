# mcurcio — personal zsh additions loaded by Oh My Zsh from $ZSH_CUSTOM
# (sourced automatically; keep bootstrap in ~/.zshrc via chezmoi dot_zshrc.tmpl)
# DO NOT EDIT THIS FILE DIRECTLY — it is generated from the chezmoi template:
#   ~/.local/share/chezmoi/dot_oh-my-zsh/custom/mcurcio.zsh.tmpl

(( ${+HOMEBREW_PREFIX} )) || eval "$(/opt/homebrew/bin/brew shellenv)"

# Added by Windsurf
export PATH="{{ .chezmoi.homeDir }}/.codeium/windsurf/bin:$HOME/.local/bin:$PATH"

# Python user-site scripts (pip3 install --user)
if command -v python3 &>/dev/null; then
  export PATH="$PATH:$(python3 -m site --user-base)/bin"
fi

# Gas Town
export GT_TOWN_ROOT="{{ .chezmoi.homeDir }}/gt"

typeset -g ZSH_SECRETS_DIR="$HOME/.secrets.d"

if [[ -d "$ZSH_SECRETS_DIR" ]]; then
  for secret_file in "$ZSH_SECRETS_DIR"/**/*.zsh(.N); do
    source "$secret_file"
  done
fi
{{- if eq .role "work" }}
# iFIT corporate TLS CA — fixes self-signed cert errors with npm, node-gyp, curl, Python, etc.
export IFIT_CERT="{{ .chezmoi.homeDir }}/Sync/iFIT/tools/assistant/certs/ifit-outbound-tls-ca.pem"
export NODE_EXTRA_CA_CERTS="$IFIT_CERT"
# HACK: Python tools (snow, pip, etc.) need the full system CA bundle + iFIT cert.
# SSL_CERT_FILE/REQUESTS_CA_BUNDLE replace rather than append. Regenerate on every shell.
# TODO: replace with pip-system-certs + macOS keychain trust
_ifit_ca_bundle="$HOME/.cache/ifit-combined-ca-bundle.pem"
if python3 -c 'import certifi' 2>/dev/null; then
  cat "$(python3 -c 'import certifi;print(certifi.where())')" "$IFIT_CERT" > "$_ifit_ca_bundle" 2>/dev/null
  export SSL_CERT_FILE="$_ifit_ca_bundle"
  export REQUESTS_CA_BUNDLE="$_ifit_ca_bundle"
fi

# Claude Code + AWS Bedrock (work profile)
export CLAUDE_CODE_USE_BEDROCK=1
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1
export ANTHROPIC_DEFAULT_OPUS_MODEL='global.anthropic.claude-opus-4-8'
export ANTHROPIC_DEFAULT_SONNET_MODEL='global.anthropic.claude-sonnet-4-6'
export ANTHROPIC_DEFAULT_HAIKU_MODEL='global.anthropic.claude-haiku-4-5-20251001-v1:0'
{{ end }}
